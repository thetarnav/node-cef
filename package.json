{
  "name": "node-cef",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "types/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b src",
    "download:cef": "bun run download-cef.ts",
    "build:cef": "cmake-js build",
    "setup": "bun run download:cef && bun run build:cef",
    "postinstall": "bun run download:cef",
    "example": "bun run example/index.ts",
    "test:bun": "bun run test/index.ts",
    "test:node": "node test/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "cmake-js": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
